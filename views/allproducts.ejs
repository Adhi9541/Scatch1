<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-sans bg-gray-50">
    <nav class="w-full bg-gradient-to-r from-indigo-600 to-purple-600 text-white shadow-lg px-8 py-4 flex justify-between items-center">
        <h3 class="text-2xl font-bold tracking-wide">Scatch</h3>
        
        <% var loggedin = typeof loggedin != "undefined" ? loggedin : true %>
        <% if (loggedin) { %>
            <div class="flex items-center gap-8 text-lg font-medium">
                <a class="block w-fit mb-2" href="/owners/allproducts">All Products</a>
                    <a class="block w-fit mb-2" href="/owners/admin">Create new product</a>
            <a  class="bg-red-500 hover:bg-red-600 px-4 py-1 rounded-lg text-white transition duration-200" href="/users/logout">Logout</a>
        </div>
        <% } %>
        
    </nav>
    </nav>
<div class="min-h-screen bg-gradient-to-br from-indigo-100 via-purple-100 to-pink-100 px-20 py-16 flex">
    
    <!-- Products Section -->
    <div class="w-[60%] grid grid-cols-3 ">

        <% products.forEach(function(product){ %>

        <div class=" ml-3 rounded-3xl overflow-hidden hover:scale-105 transition duration-300">

            <div class="w-full h-56 flex items-center justify-center bg-gradient-to-br from-indigo-500 to-purple-600">
                <img class="h-44 object-contain drop-shadow-2xl"
                     src="data:image/png;base64,<%= product.image.toString('base64') %>" 
                     alt="">
            </div>

            <div class="px-5 py-5 bg-gradient-to-r from-purple-600 to-pink-500 text-white flex justify-between items-center">

                <div>
                    <h3 class="text-lg font-semibold"> Product Name : <%= product.name %></h3>
                    <h4 class="text-sm opacity-90"> Product Price : ₹ <%= product.price %></h4>
                    <h4 class="text-sm opacity-90"> Product Discount Price :₹ <%= product.discount %></h4>

                </div>

            </div>

        </div>

        <% }) %>
 
    </div>

</div>

</body>
</html>
