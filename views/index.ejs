<%- include('./partials/header') %>

<div class="min-h-screen bg-gradient-to-br from-indigo-200 via-purple-200 to-pink-200 flex items-center justify-center px-20">

    <% if(error && error.length > 0){ %>
        <div class="absolute top-6 left-1/2 -translate-x-1/2 px-6 py-3 rounded-xl bg-red-500 shadow-lg">
            <span class="text-white font-medium">
                <%= error %>
            </span>
        </div>
    <% } %>

    <div class="w-full max-w-6xl flex bg-white shadow-2xl rounded-3xl overflow-hidden">

        <!-- Register Section -->
        <div class="w-1/2 p-16 bg-gradient-to-br from-white to-indigo-50">

            <h3 class="text-4xl font-bold mb-2">
                Welcome to <span class="text-indigo-600">Scatch</span>
            </h3>

            <h4 class="text-xl text-gray-600 mb-8">
                Create your account
            </h4>

            <form autocomplete="off" action="/users/register" method="post">

                <input
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    type="text" placeholder="Full Name" name="fullname">

                <input
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 mb-4 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    type="email" placeholder="Email" name="email">

                <input
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 mb-6 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                    type="password" placeholder="Password" name="password">

                <button
                    class="w-full py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover:scale-105 transition duration-300 shadow-lg">
                    Create My Account 🚀
                </button>

            </form>

        </div>

        <!-- Login Section -->
        <div class="w-1/2 p-16 bg-gradient-to-br from-indigo-50 to-purple-100">

            <h4 class="text-3xl font-bold mb-2 text-gray-800">
                Login to your account
            </h4>

            <p class="text-gray-600 mb-8">
                Welcome back 👋
            </p>

            <form autocomplete="off" action="/users/login" method="post">

                <input
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 mb-4 focus:outline-none focus:ring-2 focus:ring-purple-400"
                    type="email" placeholder="Email" name="email">

                <input
                    class="w-full px-4 py-3 rounded-xl border border-gray-300 mb-6 focus:outline-none focus:ring-2 focus:ring-purple-400"
                    type="password" placeholder="Password" name="password">

                <button
                    class="w-full py-3 rounded-xl bg-gradient-to-r from-purple-600 to-pink-500 text-white font-semibold hover:scale-105 transition duration-300 shadow-lg">
                    Login 🔐
                </button>

            </form>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>
