<%- include('./partials/header') %>

<div class="min-h-screen flex bg-gradient-to-br from-pink-200 via-purple-200 to-indigo-200">

  <!-- Sidebar -->
  <div class="w-64 bg-gradient-to-b from-purple-700 via-indigo-700 to-blue-700 text-white shadow-2xl p-8 flex flex-col backdrop-blur-lg">

    <h2 class="text-3xl font-extrabold mb-12 tracking-wide">
      🚀 Admin Panel
    </h2>

    <a class="mb-5 px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/20 hover:scale-105 transition duration-300 font-semibold"
       href="/owners/allproducts">
      📦 All Products
    </a>

    <a class="mb-5 px-5 py-3 rounded-2xl bg-white/10 hover:bg-white/20 hover:scale-105 transition duration-300 font-semibold"
       href="/owners/admin">
      ➕ Create Product
    </a>

  </div>

  <!-- Main Content -->
  <div class="flex-1 p-12">

    <div class="flex justify-between items-center mb-12">

      <h1 class="text-5xl font-extrabold bg-gradient-to-r from-purple-600 via-pink-500 to-indigo-600 bg-clip-text text-transparent">
        🌈 Products Dashboard
      </h1>

      <a class="px-6 py-3 rounded-2xl bg-gradient-to-r from-red-500 to-pink-600 text-white font-semibold shadow-xl hover:scale-110 transition duration-300"
         href="">
        🗑 Delete All
      </a>

    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-4 gap-10">

      <% for(let i=0;i<4;i++){ %>

      <div class="bg-white rounded-3xl shadow-2xl hover:shadow-purple-300 hover:scale-105 transition duration-300 overflow-hidden">

        <div class="h-56 bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 flex items-center justify-center">
          <span class="text-white text-xl font-bold tracking-wide">
            👜 Image
          </span>
        </div>

        <div class="flex justify-between items-center p-6 bg-gradient-to-r from-purple-50 to-pink-50">

          <div>
            <h3 class="font-bold text-gray-800 text-xl">Clinge Bag</h3>
            <h4 class="text-purple-600 font-extrabold text-lg">₹ 1200</h4>
          </div>

          <a class="w-12 h-12 flex items-center justify-center rounded-full bg-gradient-to-r from-indigo-600 to-pink-500 text-white text-xl shadow-lg hover:scale-110 transition"
             href="">
            +
          </a>

        </div>

      </div>

      <% } %>

    </div>

  </div>

</div>

<%- include('./partials/footer') %>
